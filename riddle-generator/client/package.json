{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:fresh": "node -e \"const{execSync}=require('child_process');try{const r=execSync('netstat -ano | findstr :3000',{encoding:'utf8'});const m=r.match(/LISTENING\\s+(\\d+)/);if(m)execSync('taskkill /PID '+m[1]+' /F',{stdio:'inherit'})}catch(e){}\" && next dev --turbopack",
    "kill-port": "node -e \"const{execSync}=require('child_process');try{const r=execSync('netstat -ano | findstr :3000',{encoding:'utf8'});const m=r.match(/LISTENING\\s+(\\d+)/);if(m){execSync('taskkill /PID '+m[1]+' /F',{stdio:'inherit'});console.log('Killed PID '+m[1])}else{console.log('Port 3000 is free')}}catch(e){console.log('Port 3000 is free')}\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^5.95.2",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "emoji-picker-react": "^4.18.0",
    "formik": "^2.4.9",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-intl": "^4.12.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "tailwind-merge": "^3.4.0",
    "webpack": "^5.105.4",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/redux-persist": "^4.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "sass": "^1.77.8",
    "typescript": "^5"
  }
