<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>{{title}}</title>
  <style>
    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background: #4a90e2; color: white; padding: 20px; text-align: center; border-radius: 8px 8px 0 0; }
    .content { background: #f9f9f9; padding: 20px; border-radius: 0 0 8px 8px; }
    .amount { font-size: 1.5em; font-weight: bold; color: #4a90e2; }
  </style>
</head>
<body>
<div class="container">
  <div class="header">
    <h1>{{title}}</h1>
  </div>
  <div class="content">
    <p>Hi {{userName}},</p>
    <p>{{{message}}}</p>
    {{#if amount}}
      <p class="amount">{{amount}} {{currency}}</p>
    {{/if}}
    <p>Thank you for using our service!</p>
    <p><em>Lullaby App Team</em></p>
  </div>
</div>
</body>
</html>
