// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String   @id @default(uuid())
  email                String   @unique @db.Text
  password             String?  @default("") @db.Text
  name                 String?  @default("") @db.Text
  avatar_url           String?  @db.Text
  is_guest             Boolean  @default(false)
  onboarding_completed Boolean? @default(false)
  created_at           DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updated_at           DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  violation_count   Int       @default(0)
  banned_until      DateTime?
  last_violation_at DateTime?

  xp             Int   @default(0)
  level          Int   @default(1)
  riddles_solved Int   @default(0)
  rating         Float @default(0.0)

  streak_count   Int       @default(0)
  last_active_at DateTime?
  xp_multiplier  Float     @default(1.0)

  sessions         Session[]
  riddles          Riddles[]
  saved_riddles    SavedRiddles[]
  comments         Comment[]
  likes            Like[]
  Chat             Chat[]
  followers        Follow[]        @relation("following")
  following        Follow[]        @relation("follower")
  SolvedRiddle     SolvedRiddle[]
  RiddleAttempt    RiddleAttempt[]
  notifications    Notification[]  @relation("NotificationRecipient")
  triggered_notifs Notification[]  @relation("NotificationActor")
  user_quests      UserQuest[]
  pvp_created      PvpMatch[]      @relation("PvpCreator")
  pvp_opposed      PvpMatch[]      @relation("PvpOpponent")
  pvp_won          PvpMatch[]      @relation("PvpWinner")
  challenge_solvers ChallengeSolver[]

  @@map("users")
}

model Follow {
  follower    User   @relation("follower", fields: [follower_id], references: [id], onDelete: Cascade)
  follower_id String

  following    User   @relation("following", fields: [following_id], references: [id], onDelete: Cascade)
  following_id String

  created_at DateTime @default(now())

  @@id([follower_id, following_id])
  @@map("follows")
}

model Session {
  id            String  @id @default(uuid())
  token         String  @unique
  refresh_token String? @unique

  created_at       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  last_activity_at DateTime? @map("last_activity_at") @db.Timestamp(6)
  expires_at       DateTime  @updatedAt @map("expires_at") @db.Timestamp(6)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@map("sessions")
}

enum NotificationType {
  COMMENT
  LIKE
  FOLLOW
  LEVEL_UP
  XP_EARNED
  PROFILE_DELETED
  NEW_RIDDLE
  RIDDLE_SOLVED
  USER_BANNED
  USER_UNBANNED
  ATTEMPTS_RESET
  QUEST_COMPLETED
  STREAK_INCREMENTED
  LEADERBOARD_RANK_UP
  PVP_CHALLENGE_RECEIVED
  PVP_MATCH_WON
  PVP_MATCH_LOST
  COMMUNITY_CHALLENGE_COMPLETED
}

enum PvpStatus {
  PENDING
  ACTIVE
  FINISHED
  CANCELLED
}

enum QuestType {
  SOLVE_RIDDLES
  EARN_XP
  MAINTAIN_STREAK
  GENERATE_IMAGE_RIDDLE
  SOLVE_MATH
  SOLVE_LOGIC
}

enum RiddleType {
  DANETKI
  CLASSIC
  LOGIC
  MATH
}

model Riddles {
  id             String @id @default(uuid())
  content        String @db.Text
  answer         String @db.Text
  prompt_context Json?

  complexity Int        @default(1)
  type       RiddleType @default(CLASSIC)

  is_public   Boolean @default(false)
  is_verified Boolean @default(false)

  image_url String? @db.Text

  likes_count    Int @default(0)
  comments_count Int @default(0)

  created_at DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updated_at DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  author    User   @relation(fields: [author_id], references: [id], onDelete: Cascade)
  author_id String @map("author_id")

  saved_by SavedRiddles[]

  comments       Comment[]
  likes          Like[]
  RiddleAttempt  RiddleAttempt[]
  source_message Message[]
  pvp_matches    PvpMatch[]

  @@map("riddles")
}

model SolvedRiddle {
  id      String @id @default(uuid())
  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  content_preview String   @db.Text
  xp_earned       Int
  at              DateTime @default(now())

  @@map("solved_riddles")
}

model SavedRiddles {
  id         String   @id @default(uuid())
  created_at DateTime @default(now()) @db.Timestamp(6)

  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id String

  riddle    Riddles @relation(fields: [riddle_id], references: [id], onDelete: Cascade)
  riddle_id String

  @@unique([user_id, riddle_id])
  @@map("saved_riddles")
}

model RiddleAttempt {
  id         String   @id @default(uuid())
  user_id    String
  riddle_id  String
  attempts   Int      @default(0)
  last_try   DateTime @default(now())
  is_blocked Boolean  @default(false)

  user   User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  riddle Riddles @relation(fields: [riddle_id], references: [id], onDelete: Cascade)

  @@unique([user_id, riddle_id])
}

model Chat {
  id      String @id @default(uuid())
  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  is_interactive        Boolean @default(false)
  current_riddle_answer String? @db.Text

  complexity Int        @default(1)
  type       RiddleType @default(LOGIC)
  language   String     @default("ukrainian")

  messages  Message[]
  createdAt DateTime  @default(now())

  @@map("chats")
}

model Message {
  id         String   @id @default(uuid())
  chat_id    String
  chat       Chat     @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  role       String
  content    String
  is_initial Boolean  @default(false)
  createdAt  DateTime @default(now())

  saved_riddle    Riddles? @relation(fields: [saved_riddle_id], references: [id])
  saved_riddle_id String?  @map("saved_riddle_id")
}

model Comment {
  id      String @id @default(uuid())
  content String @db.Text

  created_at DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updated_at DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  user      User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id   String  @map("user_id")
  riddle    Riddles @relation(fields: [riddle_id], references: [id], onDelete: Cascade)
  riddle_id String  @map("riddle_id")

  @@map("comments")
}

model Like {
  id         String   @id @default(uuid())
  created_at DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user      User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id   String  @map("user_id")
  riddle    Riddles @relation(fields: [riddle_id], references: [id], onDelete: Cascade)
  riddle_id String  @map("riddle_id")

  @@unique([user_id, riddle_id])
  @@map("likes")
}

model Notification {
  id       String           @id @default(uuid())
  type     NotificationType
  content  String           @db.Text
  isRead   Boolean          @default(false)
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user   User   @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  actor   User?   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorId String? @map("actor_id")

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model AIPrompt {
  id       String @id @default(uuid())
  name     String @unique
  template String @db.Text

  created_at DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updated_at DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("ai_prompts")
}

model Quest {
  id           String    @id @default(uuid())
  title        String    @db.Text
  description  String    @db.Text
  xp_reward    Int
  quest_type   QuestType
  target_count Int
  expires_at   DateTime
  is_active    Boolean   @default(true)

  user_quests UserQuest[]

  created_at DateTime @default(now())

  @@map("quests")
}

model UserQuest {
  id           String    @id @default(uuid())
  progress     Int       @default(0)
  is_completed Boolean   @default(false)
  completed_at DateTime?

  user     User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id  String
  quest    Quest  @relation(fields: [quest_id], references: [id], onDelete: Cascade)
  quest_id String

  @@unique([user_id, quest_id])
  @@map("user_quests")
}

// ─── PvP ──────────────────────────────────────────────────────

model PvpMatch {
  id     String    @id @default(uuid())
  status PvpStatus @default(PENDING)

  creator    User   @relation("PvpCreator", fields: [creator_id], references: [id], onDelete: Cascade)
  creator_id String

  opponent    User?   @relation("PvpOpponent", fields: [opponent_id], references: [id], onDelete: SetNull)
  opponent_id String?

  winner    User?   @relation("PvpWinner", fields: [winner_id], references: [id], onDelete: SetNull)
  winner_id String?

  riddle    Riddles? @relation(fields: [riddle_id], references: [id], onDelete: SetNull)
  riddle_id String?

  created_at  DateTime  @default(now())
  started_at  DateTime?
  finished_at DateTime?

  @@index([creator_id])
  @@index([opponent_id])
  @@map("pvp_matches")
}

// ─── Community Challenges ─────────────────────────────────────

model CommunityChallenge {
  id                String   @id @default(uuid())
  title             String   @db.Text
  description       String   @db.Text
  riddle_content    String   @db.Text
  riddle_answer     String   @db.Text
  riddle_type       String   @default("LOGIC")
  riddle_complexity Int      @default(5)
  xp_reward         Int
  starts_at         DateTime
  ends_at           DateTime
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now())

  solvers ChallengeSolver[]

  @@map("community_challenges")
}

model ChallengeSolver {
  id        String   @id @default(uuid())
  solved_at DateTime @default(now())

  user         User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id      String
  challenge    CommunityChallenge @relation(fields: [challenge_id], references: [id], onDelete: Cascade)
  challenge_id String

  @@unique([user_id, challenge_id])
  @@map("challenge_solvers")
}
